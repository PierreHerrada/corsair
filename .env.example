# =============================================================================
# Corsair — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Integrations are opt-in: if env vars are missing, the integration is inactive.
# =============================================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...             # Anthropic API key for Claude

# --- Database ---
DATABASE_URL=postgres://user:pass@localhost:5432/corsair  # PostgreSQL connection string

# --- Slack Integration ---
SLACK_BOT_TOKEN=xoxb-...                 # Slack bot OAuth token
SLACK_APP_TOKEN=xapp-...                 # Slack app-level token (Socket Mode)

# --- Jira Integration ---
JIRA_BASE_URL=https://company.atlassian.net  # Jira instance URL
JIRA_EMAIL=you@company.com              # Jira account email
JIRA_API_TOKEN=...                       # Jira API token
JIRA_PROJECT_KEY=SWE                     # Jira project key

# --- GitHub Integration ---
GITHUB_TOKEN=ghp_...                     # GitHub personal access token (repo scope)
GITHUB_ORG=your-org                      # GitHub organization name

# --- App ---
ADMIN_PASSWORD=changeme                  # Admin password for the web UI
ENVIRONMENT=development                  # development | production
